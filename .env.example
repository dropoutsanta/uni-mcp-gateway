# ── Required ──────────────────────────────────────────────────────────────────

# Admin API key — used to bootstrap the first admin key on startup
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=your-secret-admin-token-here

# Public base URL of this gateway (used for webhook URLs, media serving, etc.)
MCP_BASE_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite database path (auto-created on first run)
GATEWAY_DB_PATH=/data/gateway.db

# ── Optional ──────────────────────────────────────────────────────────────────

# Admin key identifier (default: "admin")
# ADMIN_KEY_ID=admin

# Server port (default: 8080)
# PORT=8080

# ── WhatsApp Plugin (optional) ────────────────────────────────────────────────

# URL of the Go WhatsApp bridge process
# WHATSAPP_BRIDGE_URL=http://localhost:7481

# ── Plugin Credentials ───────────────────────────────────────────────────────
# Plugin credentials are stored in the database and managed via admin tools.
# Set them after first run using:
#   gateway_set_credentials(key_id="admin", plugin="gmail", credentials={
#     "client_id": "...",
#     "client_secret": "...",
#     "refresh_token": "..."
#   })
